---
const products = [
  {
    title: "Structural Components",
    href: "/products#structural-components",
    index: "01",
    image: "/images/product-structural.jpg",
    alt: "Robotic press cell forming a structural component",
    className: "md:col-span-3 h-80",
    imageClass: "object-center",
    heading: "text-2xl",
  },
  {
    title: "Class A Trim",
    href: "/products#class-a-trim",
    index: "02",
    image: "/images/product-decorative-trim.jpg",
    alt: "Operator handling decorative trim parts at a press line",
    className: "md:col-span-3 h-80",
    imageClass: "object-center",
    heading: "text-2xl",
  },
  {
    title: "Exhaust Parts",
    href: "/products#exhaust-components",
    index: "03",
    image: "/images/product-exhaust-parts.jpg",
    alt: "Gloved operator positioning a formed exhaust part in a fixture",
    className: "md:col-span-2 h-72",
    imageClass: "object-center",
    heading: "text-xl",
  },
  {
    title: "Class A Wheel Cladding",
    href: "/products#wheel-cladding",
    index: "04",
    image: "/images/product-wheel-claddings.jpg",
    alt: "Laser welding sparks during metal forming work",
    className: "md:col-span-2 h-72",
    imageClass: "object-center",
    heading: "text-xl",
  },
  {
    title: "EV · Appliance · Building",
    href: "/products#ev-industrial",
    index: "05",
    image: "/images/product-ev-appliance-building.jpg",
    alt: "Welder assembling a metal component with sparks",
    className: "md:col-span-2 h-72",
    imageClass: "object-center",
    heading: "text-xl",
  },
];
---

<section id="products" class="py-24">
  <div class="site-container">
    <p class="eyebrow mb-3">03 — Product Categories</p>
    <h2 class="section-title mb-12 max-w-2xl">From decorative trim to structural assemblies.</h2>
    <div class="grid grid-cols-1 gap-4 md:grid-cols-6">
      {products.map((product) => (
        <a
          href={product.href}
          class:list={[product.className, "product-card group relative overflow-hidden"]}
          aria-label={`Explore ${product.title}`}
        >
          <img
            src={product.image}
            alt={product.alt}
            class:list={[
              product.imageClass,
              "duotone h-full w-full object-cover transition duration-700 group-hover:scale-105",
            ]}
          />
          <div class="card-overlay absolute inset-0"></div>
          <div class="absolute bottom-6 left-6">
            <p class="eyebrow mb-1 text-primary">{product.index}</p>
            <h3 class:list={[product.heading, "font-semibold text-foreground"]}>{product.title}</h3>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .product-card:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 4px;
  }
</style>
