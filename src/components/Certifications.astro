---
const certifications = ["IATF 16949:2016", "PPAP", "Process Capability", "CAD Inspection"];
---

<section class="border-y border-line bg-surface py-12">
  <div class="site-container flex flex-wrap items-center justify-between gap-8">
    <p class="eyebrow">Quality & Certifications</p>
    <div class="flex flex-wrap items-center gap-10 text-muted">
      {certifications.map((certification) => (
        <div class="text-xl font-bold tracking-tight">{certification}</div>
      ))}
    </div>
  </div>
</section>
