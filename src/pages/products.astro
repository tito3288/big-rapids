---
import SiteLayout from "../layouts/SiteLayout.astro";

const title = "Automotive Metal Stampings & Assemblies | Big Rapids Products";
const description =
  "Precision automotive metal stampings, exhaust components, structural assemblies, Class A trim, wheel cladding, and EV and industrial components.";

const productFamilies = [
  { title: "Exhaust Components", href: "#exhaust-components" },
  { title: "Class A Trim", href: "#class-a-trim" },
  { title: "Structural Components", href: "#structural-components" },
  { title: "Wheel Cladding", href: "#wheel-cladding" },
  { title: "EV & Industrial", href: "#ev-industrial" },
];

const exhaustComponents = [
  "Exhaust Manifolds",
  "Muffler Shells",
  "Muffler & Resonator Housings",
  "Internal Muffler Components",
  "Catalytic-Converter End Cones",
  "Y Collectors",
  "Heat Shields",
  "Gas Diverters",
  "Exhaust-Pipe Hangers",
];

const trimApplications = [
  "Class A Exterior Trim",
  "Exhaust Tips",
  "Interior Products",
  "Stainless-Steel Trim",
  "Aluminum Trim",
  "Roll-Formed Components",
];

const structuralComponents = [
  "Frame & Body Reinforcements",
  "Seating Components",
  "A, B & C Pillar Reinforcements",
  "Sunroof Reinforcements",
  "Door-Handle Components",
  "Engineered Brackets",
];

const structuralSequence = [
  { title: "Stamping", copy: "Precision-formed components produced for repeatable automotive programs." },
  { title: "Robotic Welding", copy: "Integrated joining supports multi-component structural assemblies." },
  { title: "Light Assembly", copy: "Hardware, components, and subassemblies are brought together efficiently." },
  { title: "Finishing Network", copy: "Required e-coating, plating, and specialized finishes are coordinated through qualified supply partners." },
];

const wheelOutcomes = [
  {
    title: "Durable Performance",
    copy: "Stainless-steel construction and specified finishes support long-term exterior performance.",
  },
  {
    title: "Premium Appearance",
    copy: "Class A surfaces create a polished, high-value appearance for finished wheel systems.",
  },
  {
    title: "Production Repeatability",
    copy: "Disciplined stamping and finishing coordination support consistent high-volume programs.",
  },
];

const industrialApplications = [
  {
    title: "Electric Vehicle",
    copy: "EV stampings, battery components, structural parts, and assemblies designed for scalable vehicle programs.",
  },
  {
    title: "Appliance",
    copy: "Precision stampings and components that combine dependable manufacturing with cosmetic requirements.",
  },
  {
    title: "Building Products",
    copy: "Repeatable metal components for building-product and related industrial manufacturing applications.",
  },
];
---

<SiteLayout title={title} description={description} canonicalPath="/products/" socialImage="/images/image-1.jpg">
  <section id="top" class="relative overflow-hidden border-b border-line bg-background pb-20 pt-44 text-muted sm:pb-24 sm:pt-52 lg:pt-56">
    <div class="site-container relative z-10 grid items-start gap-14 lg:grid-cols-[minmax(0,1.18fr)_minmax(23rem,0.82fr)] lg:gap-14">
      <div class="min-w-0">
        <p class="eyebrow text-primary">Products · Automotive & Industrial</p>
        <h1 class="hero-title page-hero-title--long mt-7 max-w-5xl">
          Precision Metal Stamping for Automotive OEMs and <span class="md:whitespace-nowrap">Tier 1 Customers</span>
        </h1>
        <p class="mt-8 max-w-3xl text-lg leading-relaxed text-foreground sm:text-xl">
          Big Rapids Products delivers precision metal stampings, welded assemblies, and engineered manufacturing solutions for automotive OEMs, Tier 1 customers, and industrial manufacturers across North America.
        </p>
        <p class="mt-5 max-w-3xl text-base leading-relaxed text-muted sm:text-lg">
          Working in stainless steel, carbon steel, aluminum, high-strength steel, coated steel, and other advanced materials, we support new launches and high-volume production with quality, repeatability, and dependable execution.
        </p>
        <div class="mt-10 flex flex-wrap gap-3">
          <a class="products-hero-action btn-red w-fit max-w-full px-6 py-4 text-center" href="#product-families">Explore Product Families ↓</a>
          <a class="ghost-button w-fit max-w-full px-6 py-4 text-center" href="/#contact">Start a Project</a>
        </div>
      </div>

      <nav id="product-families" class="scroll-mt-32 border-l border-t border-line" aria-label="Product families">
        <div class="border-b border-r border-line p-6 sm:p-7">
          <p class="text-xs font-black uppercase tracking-[0.24em] text-muted">Product Portfolio</p>
          <p class="mt-3 text-2xl font-bold leading-tight text-foreground">Five product families. One accountable manufacturing partner.</p>
        </div>
        <div class="grid sm:grid-cols-2">
          {productFamilies.map((family) => (
            <a
              href={family.href}
              class="group grid min-h-24 grid-cols-[1fr_auto] items-center gap-3 border-b border-r border-line p-5 text-foreground transition hover:bg-foreground hover:text-background"
            >
              <span class="font-bold text-current">{family.title}</span>
              <span class="text-primary transition group-hover:translate-y-1">↓</span>
            </a>
          ))}
        </div>
      </nav>
    </div>
  </section>

  <section id="exhaust-components" class="scroll-mt-20 bg-paper py-20 text-paper-muted sm:py-24 lg:py-28">
    <div class="site-container">
      <div class="grid gap-7 border-b border-paper-line pb-12 md:grid-cols-[8rem_1fr] md:gap-10 lg:grid-cols-[8rem_minmax(0,1.05fr)_minmax(21rem,0.75fr)]">
        <p class="text-xs font-black uppercase tracking-[0.24em] text-primary">Exhaust</p>
        <div>
          <p class="text-xs font-black uppercase tracking-[0.22em]">Automotive Components</p>
          <h2 class="display-heading mt-5 max-w-5xl text-[clamp(2.5rem,3.9vw,4rem)] font-bold leading-[0.98] tracking-[-0.035em] text-ink">
            Precision Exhaust Components for Automotive Manufacturing
          </h2>
        </div>
        <div class="space-y-5 md:col-start-2 lg:col-start-auto">
          <p class="text-lg leading-relaxed">
            Big Rapids Products supplies precision-stamped exhaust components for automotive OEM and Tier 1 programs, combining forming expertise, engineering support, and dependable production execution.
          </p>
          <p class="leading-relaxed">
            From launch through ongoing production, disciplined manufacturing processes help customers maintain quality, repeatability, and output at scale.
          </p>
        </div>
      </div>

      <div class="mt-14 grid items-start gap-10 lg:grid-cols-[minmax(0,0.95fr)_minmax(24rem,1.05fr)] lg:gap-14">
        <div>
          <ul class="grid border-l border-t border-paper-line sm:grid-cols-2" aria-label="Exhaust components">
            {exhaustComponents.map((component) => (
              <li class="flex min-h-20 items-center border-b border-r border-paper-line p-4 font-bold text-ink">
                <span>{component}</span>
              </li>
            ))}
          </ul>
        </div>

        <figure class="aspect-[3/2] w-full overflow-hidden border border-paper-line bg-ink lg:sticky lg:top-32 lg:self-start">
          <img
            src="/images/product-exhaust-parts.jpg"
            alt="Big Rapids Products stamped exhaust components displayed together"
            class="h-full w-full object-cover object-center"
            loading="lazy"
            decoding="async"
          />
        </figure>
      </div>
    </div>
  </section>

  <section id="class-a-trim" class="scroll-mt-20 bg-secondary py-20 text-foreground sm:py-24 lg:py-28">
    <div class="site-container">
      <div class="grid items-start gap-12 lg:grid-cols-[minmax(22rem,0.88fr)_minmax(0,1.12fr)] lg:gap-16">
        <div class="lg:sticky lg:top-32 lg:self-start">
          <p class="text-xs font-black uppercase tracking-[0.24em] text-foreground/65">Appearance Products</p>
          <figure class="mt-8 aspect-[4/3] w-full overflow-hidden border border-foreground/20 bg-background">
            <img
              src="/images/product-decorative-trim.jpg"
              alt="Big Rapids Products Class A decorative trim components"
              class="h-full w-full object-cover object-center"
              loading="lazy"
              decoding="async"
            />
          </figure>
        </div>

        <div>
          <p class="text-xs font-black uppercase tracking-[0.22em] text-foreground/65">Class A Trim</p>
          <h2 class="display-heading mt-5 max-w-4xl text-[clamp(2.6rem,4.1vw,4.25rem)] font-bold leading-[0.96] tracking-[-0.04em]">
            Class A Trim & Appearance Components
          </h2>
          <p class="mt-7 max-w-3xl text-lg leading-relaxed text-foreground/80">
            Big Rapids Products manufactures precision-stamped and roll-formed stainless-steel and aluminum trim components for demanding automotive programs.
          </p>
          <p class="mt-5 max-w-3xl leading-relaxed text-foreground/75">
            From exterior trim and exhaust tips to interior and cosmetic applications, these products are built for premium appearance, consistent surface quality, and repeatable high-volume production.
          </p>

          <ul class="mt-10 flex flex-wrap gap-2" aria-label="Class A trim applications">
            {trimApplications.map((application) => (
              <li class="border border-foreground/25 px-4 py-3 text-xs font-black uppercase tracking-[0.14em]">{application}</li>
            ))}
          </ul>

        </div>
      </div>

      <div class="mt-12 grid border-l border-t border-foreground/20 md:grid-cols-3">
        <article class="border-b border-r border-foreground/20 p-6 sm:p-7">
          <p class="text-xs font-black uppercase tracking-[0.18em] text-foreground/55">Surface</p>
          <h3 class="mt-5 text-xl font-bold">Premium Appearance</h3>
        </article>
        <article class="border-b border-r border-foreground/20 p-6 sm:p-7">
          <p class="text-xs font-black uppercase tracking-[0.18em] text-foreground/55">Process</p>
          <h3 class="mt-5 text-xl font-bold">Stamping & Roll Forming</h3>
        </article>
        <article class="border-b border-r border-foreground/20 p-6 sm:p-7">
          <p class="text-xs font-black uppercase tracking-[0.18em] text-foreground/55">Production</p>
          <h3 class="mt-5 text-xl font-bold">Repeatable at Scale</h3>
        </article>
      </div>
    </div>
  </section>

  <section id="structural-components" class="scroll-mt-20 bg-paper py-20 text-paper-muted sm:py-24 lg:py-28">
    <div class="site-container">
      <div class="grid gap-7 border-b border-paper-line pb-12 md:grid-cols-[8rem_1fr] md:gap-10 lg:grid-cols-[8rem_minmax(0,1fr)_minmax(21rem,0.72fr)]">
        <p class="text-xs font-black uppercase tracking-[0.24em] text-primary">Structural</p>
        <div>
          <p class="text-xs font-black uppercase tracking-[0.22em]">Stampings & Assemblies</p>
          <h2 class="display-heading mt-5 max-w-5xl text-[clamp(2.5rem,3.9vw,4rem)] font-bold leading-[0.98] tracking-[-0.035em] text-ink">
            Structural Automotive Stampings & Assemblies
          </h2>
        </div>
        <div class="md:col-start-2 lg:col-start-auto">
          <p class="text-lg leading-relaxed">
            Precision stamping, welding, and light assembly come together to support structural components that must meet demanding vehicle-program requirements.
          </p>
        </div>
      </div>

      <div class="mt-14 grid items-start gap-10 lg:grid-cols-[minmax(0,1.05fr)_minmax(24rem,0.95fr)] lg:gap-14">
        <div>
          <ul class="grid border-l border-t border-paper-line sm:grid-cols-2" aria-label="Structural automotive components">
            {structuralComponents.map((component) => (
              <li class="flex min-h-24 items-center border-b border-r border-paper-line p-5 font-bold text-ink">
                <span>{component}</span>
              </li>
            ))}
          </ul>
        </div>

        <figure class="aspect-[3/2] w-full overflow-hidden border border-paper-line bg-ink lg:sticky lg:top-32 lg:self-start">
          <img
            src="/images/home-structural-components.jpg"
            alt="Big Rapids Products structural stampings and assemblies"
            class="h-full w-full object-cover object-center"
            loading="lazy"
            decoding="async"
          />
        </figure>
      </div>

      <div class="mt-14 grid border-l border-t border-paper-line sm:grid-cols-2 xl:grid-cols-4">
        {structuralSequence.map((step) => (
          <article class="border-b border-r border-paper-line p-6 sm:p-7">
            <div>
              <h3 class="text-xl font-bold text-ink">{step.title}</h3>
              <p class="mt-4 leading-relaxed">{step.copy}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="wheel-cladding" class="scroll-mt-20 border-y border-line bg-surface py-20 text-muted sm:py-24 lg:py-28">
    <div class="site-container">
      <div class="grid items-start gap-12 lg:grid-cols-[minmax(22rem,0.88fr)_minmax(0,1.12fr)] lg:gap-16">
        <div class="lg:sticky lg:top-32 lg:self-start">
          <p class="text-xs font-black uppercase tracking-[0.24em] text-primary">Wheel Systems</p>
          <figure class="mt-8 aspect-[4/3] w-full overflow-hidden border border-line bg-background">
            <img
              src="/images/product-wheel-claddings.jpg"
              alt="Big Rapids Products Class A wheel cladding component"
              class="h-full w-full object-cover object-center"
              loading="lazy"
              decoding="async"
            />
          </figure>
        </div>

        <div>
          <p class="eyebrow">Class A Components</p>
          <h2 class="section-title mt-5 max-w-4xl">Class A Wheel Cladding Components</h2>
          <p class="mt-7 max-w-3xl text-lg leading-relaxed text-foreground">
            Big Rapids Products supplies precision-stamped stainless-steel wheel-cladding components for high-volume automotive production, including systems featured on popular truck platforms.
          </p>
          <p class="mt-5 max-w-3xl leading-relaxed">
            After precision stamping, required buffing and nickel-chrome finishing can be coordinated through an integrated supply network to deliver durability, premium appearance, and consistent production quality.
          </p>

        </div>
      </div>

      <div class="mt-12 grid border-l border-t border-line md:grid-cols-3">
        {wheelOutcomes.map((outcome) => (
          <article class="border-b border-r border-line p-6 sm:p-7">
            <h3 class="text-xl font-bold text-foreground">{outcome.title}</h3>
            <p class="mt-4 max-w-md leading-relaxed">{outcome.copy}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="ev-industrial" class="scroll-mt-20 bg-paper py-20 text-paper-muted sm:py-24 lg:py-28">
    <div class="site-container">
      <div class="grid gap-7 border-b border-paper-line pb-12 md:grid-cols-[8rem_1fr] md:gap-10 lg:grid-cols-[8rem_minmax(0,1fr)_minmax(21rem,0.72fr)]">
        <p class="text-xs font-black uppercase tracking-[0.24em] text-primary">Emerging Markets</p>
        <div>
          <p class="text-xs font-black uppercase tracking-[0.22em]">Automotive & Industrial</p>
          <h2 class="display-heading mt-5 max-w-5xl text-[clamp(2.5rem,3.9vw,4rem)] font-bold leading-[0.98] tracking-[-0.035em] text-ink">
            Electric Vehicle & Industrial Manufacturing Solutions
          </h2>
        </div>
        <div class="md:col-start-2 lg:col-start-auto">
          <p class="text-lg leading-relaxed">
            Big Rapids Products supplies precision metal stampings and assemblies for electric vehicles, appliances, and building products with manufacturing solutions designed for quality, scalability, and dependable production performance.
          </p>
        </div>
      </div>

      <div class="mt-14 grid items-start gap-10 lg:grid-cols-[minmax(22rem,0.88fr)_minmax(0,1.12fr)] lg:gap-14">
        <figure class="aspect-[3/2] w-full overflow-hidden border border-paper-line bg-ink lg:sticky lg:top-32 lg:self-start">
          <img
            src="/images/home-ev-appliance-building.jpg"
            alt="Big Rapids Products appliance component stampings"
            class="h-full w-full object-cover object-center"
            loading="lazy"
            decoding="async"
          />
        </figure>

        <div class="grid border-l border-t border-paper-line">
          {industrialApplications.map((application) => (
            <article class="border-b border-r border-paper-line p-6 sm:p-7">
              <div>
                <h3 class="text-2xl font-bold text-ink">{application.title}</h3>
                <p class="mt-4 max-w-2xl leading-relaxed">{application.copy}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="relative overflow-hidden border-t border-line bg-background py-20 text-muted sm:py-24 lg:py-28">
    <div class="site-container relative z-10">
      <p class="eyebrow text-primary">Start the Conversation</p>
      <div class="mt-7 border-t border-line pt-10">
        <div class="max-w-5xl">
          <h2 class="display-heading text-[clamp(2.6rem,3.9vw,4rem)] font-bold leading-[0.98] tracking-[-0.04em] text-foreground">
            From individual stampings to production-ready assemblies.
          </h2>
          <p class="mt-6 max-w-3xl text-lg leading-relaxed">
            Bring your next automotive or industrial program to a team built to improve manufacturability, reduce supplier complexity, and deliver dependable production.
          </p>
          <div class="mt-9 flex flex-col gap-3 sm:flex-row sm:flex-wrap">
            <a class="btn-red w-full px-7 py-5 text-center sm:w-auto" href="/#contact">Start a Project</a>
            <a class="ghost-button w-full px-7 py-5 text-center sm:w-auto" href="/capabilities">Explore Capabilities</a>
          </div>
        </div>
      </div>
    </div>
  </section>
</SiteLayout>

<style>
  .products-hero-action {
    white-space: normal;
  }
</style>
