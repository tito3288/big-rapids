---
import SiteLayout from "../layouts/SiteLayout.astro";
import Hero from "../components/Hero.astro";
import PositioningIntro from "../components/PositioningIntro.astro";
import Capabilities from "../components/Capabilities.astro";
import Materials from "../components/Materials.astro";
import ProductCategories from "../components/ProductCategories.astro";
import Certifications from "../components/Certifications.astro";
import Footprint from "../components/Footprint.astro";
import Careers from "../components/Careers.astro";
import ContactForm from "../components/ContactForm.astro";

const title = "Precision Metal Stamping & Assembly Solutions | Big Rapids Products";
const description =
  "Precision metal stamping, robotic welding, and engineered assemblies for automotive OEMs, Tier 1 customers, and industrial manufacturers.";
---

<SiteLayout title={title} description={description} canonicalPath="/" socialImage="/images/image-1.jpg">
	<Hero />
	<PositioningIntro />
	<Capabilities />
	<Materials />
	<ProductCategories />
	<Certifications />
	<Footprint />
	<Careers />
	<ContactForm />
</SiteLayout>
