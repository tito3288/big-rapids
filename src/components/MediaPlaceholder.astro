---
interface Props {
  slotId: string;
  label: string;
  suggestedSubject: string;
  aspect?: "hero" | "landscape" | "panoramic" | "portrait" | "wide";
  tone?: "dark" | "light" | "oxblood";
  class?: string;
}

const {
  slotId,
  label,
  suggestedSubject,
  aspect = "landscape",
  tone = "dark",
  class: className = "",
} = Astro.props;

const aspectClasses = {
  hero: "aspect-[4/3]",
  landscape: "aspect-video",
  panoramic: "aspect-[4/3] sm:aspect-[16/7]",
  portrait: "aspect-[4/5]",
  wide: "aspect-[3/2]",
};

const toneClasses = {
  dark: "border-line bg-surface text-foreground [--placeholder-line:var(--color-line)]",
  light: "border-paper-line bg-paper text-ink [--placeholder-line:var(--color-paper-line)]",
  oxblood: "border-foreground/20 bg-secondary text-foreground [--placeholder-line:var(--color-line)]",
};
---

<figure
  class:list={[
    "media-placeholder relative isolate overflow-hidden border",
    aspectClasses[aspect],
    toneClasses[tone],
    className,
  ]}
  data-image-slot={slotId}
>
  <div class="absolute inset-0 placeholder-grid" aria-hidden="true"></div>
  <div class="absolute left-1/2 top-0 h-full w-px -translate-x-1/2 bg-[var(--placeholder-line)]" aria-hidden="true"></div>
  <div class="absolute left-0 top-1/2 h-px w-full -translate-y-1/2 bg-[var(--placeholder-line)]" aria-hidden="true"></div>
  <div class="absolute left-1/2 top-1/2 size-12 -translate-x-1/2 -translate-y-1/2 border border-current/30" aria-hidden="true"></div>

  <div class="relative z-10 flex h-full flex-col justify-between p-5 sm:p-7">
    <div class="flex items-start justify-between gap-5 text-[0.65rem] font-black uppercase tracking-[0.24em]">
      <span>Image Slot {slotId}</span>
      <span class="text-right opacity-60">{label}</span>
    </div>

    <figcaption class="min-w-0 max-w-lg border-l-2 border-primary pl-4">
      <p class="text-xs font-black uppercase tracking-[0.22em] opacity-60">Image Selection Pending</p>
      <p class="mt-3 break-words text-base font-semibold leading-snug sm:text-xl">{suggestedSubject}</p>
    </figcaption>
  </div>
</figure>

<style>
  .placeholder-grid {
    background-image:
      linear-gradient(to right, var(--placeholder-line) 1px, transparent 1px),
      linear-gradient(to bottom, var(--placeholder-line) 1px, transparent 1px);
    background-size: 3rem 3rem;
  }
</style>
