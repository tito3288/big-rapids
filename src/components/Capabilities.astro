---
const stats = [
  {
    value: "60+",
    label: "Presses",
    detail: "Line, Progressive and Transfer",
  },
  {
    value: "2200",
    unit: "T",
    label: "Maximum press capacity",
    detail: "Transfer Press Tonnage",
  },
  {
    value: "110 x 300",
    unit: "in.",
    label: "Maximum bed size",
    detail: "Transfer Press",
    compact: true,
  },
  {
    value: "50-2200",
    unit: "T",
    label: "Stamping range",
    detail: "Production Press Capacity",
    compact: true,
  },
];

const services = [
  "Tool Design",
  "Prototypes",
  "Engineering",
  "Metal Stamping",
  "Roll Forming",
  "Robotic Welding",
  "Engineered Assemblies",
];
---

<section id="capabilities" class="border-t border-line py-20 md:py-24">
  <div class="site-container">
    <div class="mb-12 grid gap-8 lg:mb-16 lg:grid-cols-[minmax(0,0.95fr)_minmax(320px,0.55fr)] lg:items-end">
      <div>
        <p class="eyebrow mb-3">Capabilities</p>
        <h2 class="section-title max-w-3xl">Built for complex stampings. Engineered to reduce risk.</h2>
      </div>
      <div class="max-w-xl lg:justify-self-end">
        <p class="text-base leading-7 text-muted md:text-lg">
          From tooling design and prototypes through engineering, metal stamping, robotic welding, and assembly, our
          integrated capabilities support dependable production from concept through launch.
        </p>
        <div class="mt-6 flex flex-wrap gap-2">
          {services.map((service) => (
            <span class="border border-line px-3 py-2 text-[0.68rem] uppercase tracking-[0.18em] text-muted">{service}</span>
          ))}
        </div>
      </div>
    </div>

    <div class="grid grid-cols-1 gap-px border border-line bg-line sm:grid-cols-2 lg:grid-cols-4">
      {stats.map((stat) => (
        <article class="flex min-h-64 min-w-0 flex-col justify-between bg-background p-6 md:p-8">
          <div>
            <div class="flex min-w-0 items-baseline gap-2">
              <span class:list={["stat-number", stat.compact && "stat-number--compact"]}>{stat.value}</span>
              {stat.unit && <span class="text-xl font-bold uppercase text-muted md:text-2xl">{stat.unit}</span>}
            </div>
          </div>
          <div>
            <div class="mb-5 h-0.5 w-12 bg-primary"></div>
            <p class="text-xs uppercase tracking-widest text-muted">{stat.label}</p>
            <p class="mt-2 text-sm leading-6 text-muted/75">{stat.detail}</p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
