---
import SiteLayout from "../layouts/SiteLayout.astro";
import MediaPlaceholder from "../components/MediaPlaceholder.astro";

const title = "Precision Metal Stamping & Robotic Welding | Big Rapids Products";
const description =
  "Advanced metal stamping, engineering, robotic welding, and assembly capabilities for automotive OEMs and Tier 1 suppliers.";
const pressSpecificationsUrl =
  "https://www.brproducts.com/wp-content/uploads/2026/03/BRP_PRESS_SPECS.pdf";

const processStages = [
  {
    number: "01",
    title: "Engineering & DFM",
    copy: "Review geometry, materials, tolerances, and production requirements early to improve manufacturability and reduce program risk.",
  },
  {
    number: "02",
    title: "Tooling & Prototypes",
    copy: "Connect tool design, prototype development, and production planning to support confident decisions before launch.",
  },
  {
    number: "03",
    title: "Metal Stamping",
    copy: "Match line, progressive, and transfer press capacity to demanding parts and high-volume production programs.",
  },
  {
    number: "04",
    title: "Welding & Assembly",
    copy: "Integrate stamped components, welding, hardware, and assembly to reduce handoffs and simplify supplier coordination.",
  },
  {
    number: "05",
    title: "Quality & Production",
    copy: "Validate the process, support launch, and maintain dependable execution through ongoing production.",
  },
];

const pressProofs = [
  { value: "60+", label: "Presses" },
  { value: "2,200", label: "Tons · Maximum" },
  { value: "110 × 300", label: "Inches · Maximum Bed" },
  { value: "3", label: "Line · Progressive · Transfer" },
];

const coreCapabilities = [
  {
    number: "01",
    title: "Metal Stamping",
    copy: "Line, progressive, and transfer stamping capacity supports complex components, varied materials, and high-volume automotive production.",
  },
  {
    number: "02",
    title: "Tool Design & Engineering",
    copy: "Complete engineering, print detailing, proposal drawings, and manufacturability improvements connect part intent to a production-ready process.",
  },
  {
    number: "03",
    title: "Digital Manufacturing",
    copy: "3-D surface modeling, surface-data scanning, full-scale plotting, and multi-axis machine programming strengthen development and tool execution.",
  },
  {
    number: "04",
    title: "Prototypes & Launch Support",
    copy: "Prototype development and coordinated launch support help teams validate decisions, resolve risk earlier, and move toward stable production.",
  },
  {
    number: "05",
    title: "Roll Forming",
    copy: "Roll-forming capabilities expand the available manufacturing approach for long profiles and programs requiring repeatable continuous forming.",
  },
  {
    number: "06",
    title: "Secondary Operations",
    copy: "Assembly and welding are coordinated in-house, while required coatings and specialized finishes can be managed through an established supply network.",
  },
];

const assemblyCapabilities = [
  "Precision Metal Stampings",
  "Robotic Welding",
  "Resistance Welding",
  "Hardware Insertion",
  "Clinching & Fastening",
  "Mechanical Assembly",
  "Value-Added Subassemblies",
  "Production-Ready Assemblies",
];

const assemblyOutcomes = [
  {
    title: "Reduce Supplier Risk",
    copy: "Consolidate stamping, joining, and assembly with one accountable manufacturing partner.",
  },
  {
    title: "Improve Manufacturing Efficiency",
    copy: "Coordinate processes, tooling, quality, and launch activity through a connected team.",
  },
  {
    title: "Lower Total Program Costs",
    copy: "Reduce duplicated handling, transportation, administration, and avoidable handoffs.",
  },
  {
    title: "Improve Quality",
    copy: "Build quality controls around the complete assembly instead of isolated component steps.",
  },
];

const weldingCapabilities = [
  "Robotic GMAW / MIG",
  "Projection Welding",
  "Resistance Welding",
  "Controlled Pulse Resistance Welding",
  "Manual Welding",
  "Semi-Automated Welding",
  "Multi-Component Assemblies",
  "Weld Monitoring",
  "In-Process Quality Verification",
];

const qualityProofs = [
  {
    title: "IATF 16949:2016",
    copy: "A quality-management system aligned with the demands of automotive production.",
  },
  {
    title: "PPAP Validation",
    copy: "Disciplined production-part approval supports launch readiness and customer requirements.",
  },
  {
    title: "CMM Inspection",
    copy: "Dimensional inspection helps confirm parts and processes against defined specifications.",
  },
  {
    title: "Process Capability",
    copy: "Statistical process information supports control, consistency, and ongoing production confidence.",
  },
];
---

<SiteLayout title={title} description={description} canonicalPath="/capabilities/" socialImage="/images/image-1.jpg">
  <section id="top" class="relative overflow-hidden border-b border-line bg-background pb-16 pt-44 text-muted sm:pb-20 sm:pt-52 lg:pb-24 lg:pt-56">
    <div class="pointer-events-none absolute -right-20 top-32 hidden text-[22rem] font-black leading-none text-foreground/[0.025] xl:block" aria-hidden="true">
      01
    </div>

    <div class="site-container relative z-10 grid items-center gap-12 lg:grid-cols-[minmax(0,0.95fr)_minmax(0,1.05fr)] lg:gap-14">
      <div class="min-w-0">
        <p class="eyebrow text-primary">Capabilities · From Concept to Production</p>
        <h1 class="hero-title mt-7 max-w-4xl text-[clamp(3rem,5.6vw,5.25rem)]">
          Advanced Metal Stamping Capabilities
        </h1>
        <p class="mt-8 max-w-2xl text-lg leading-relaxed text-foreground sm:text-xl">
          With more than 60 line, progressive, and transfer presses up to 2,200 tons, Big Rapids Products provides precision metal stamping, tooling design, prototyping, engineering support, and high-volume production for automotive OEMs and Tier 1 suppliers.
        </p>
        <p class="mt-5 max-w-2xl text-base leading-relaxed text-muted sm:text-lg">
          From concept to production, we help customers reduce program risk through engineering-driven manufacturing and dependable execution.
        </p>
        <div class="mt-10 flex flex-wrap gap-3">
          <a
            class="capabilities-spec-action btn-red w-fit max-w-full px-5 py-4 text-center sm:px-6"
            href={pressSpecificationsUrl}
            target="_blank"
            rel="noopener noreferrer"
          >View Press Specifications ↗</a>
          <a class="ghost-button w-fit max-w-full px-6 py-4 text-center" href="/#contact">Start a Project</a>
        </div>
      </div>

      <MediaPlaceholder
        slotId="01"
        label="Hero Establishing Image"
        suggestedSubject="Wide press line or plant-floor view showing scale, equipment, and an active manufacturing environment."
        aspect="panoramic"
        tone="dark"
        class="min-w-0"
      />
    </div>
  </section>

  <section class="bg-paper py-20 text-paper-muted sm:py-24 lg:py-28">
    <div class="site-container">
      <div class="grid gap-7 border-b border-paper-line pb-12 md:grid-cols-[8rem_1fr] md:gap-10">
        <p class="text-xs font-black uppercase tracking-[0.24em] text-primary">01 · Process</p>
        <div>
          <p class="text-xs font-black uppercase tracking-[0.22em] text-paper-muted">From Concept to Production</p>
          <h2 class="mt-5 max-w-4xl text-[clamp(2.4rem,4.6vw,4.5rem)] font-bold leading-[0.98] tracking-[-0.035em] text-ink">
            One manufacturing partner from design through launch.
          </h2>
          <p class="mt-6 max-w-3xl text-lg leading-relaxed">
            Engineering, tooling, automation, and production teams work as one system—improving manufacturability, reducing handoffs, and supporting dependable execution from early review through stable production.
          </p>
        </div>
      </div>

      <div class="mt-14 grid gap-10 lg:grid-cols-[minmax(18rem,0.72fr)_minmax(0,1.28fr)] lg:items-start lg:gap-14">
        <MediaPlaceholder
          slotId="02"
          label="Engineering & Tooling"
          suggestedSubject="CAD review, surface scanning, tooling detail, or die-development activity with a technical human element."
          aspect="landscape"
          tone="light"
          class="lg:sticky lg:top-32"
        />

        <ol class="grid border-l border-t border-paper-line sm:grid-cols-2">
          {processStages.map((stage, index) => (
            <li
              class:list={[
                "flex min-h-60 flex-col border-b border-r border-paper-line p-6 sm:p-7",
                { "sm:col-span-2 sm:min-h-0 sm:flex-row sm:items-start sm:gap-10": index === processStages.length - 1 },
              ]}
            >
              <span class="text-xs font-black tracking-[0.18em] text-primary">{stage.number}</span>
              <div class:list={["mt-auto pt-10", { "sm:mt-0 sm:flex-1 sm:pt-0": index === processStages.length - 1 }]}>
                <h3 class="text-xl font-bold text-ink">{stage.title}</h3>
                <p class="mt-4 max-w-xl leading-relaxed">{stage.copy}</p>
              </div>
            </li>
          ))}
        </ol>
      </div>
    </div>
  </section>

  <section class="border-y border-line bg-surface py-20 text-muted sm:py-24 lg:py-28">
    <div class="site-container">
      <div class="grid gap-7 md:grid-cols-[8rem_1fr] md:gap-10">
        <p class="text-xs font-black uppercase tracking-[0.24em] text-primary">02 · Capacity</p>
        <div class="flex flex-col justify-between gap-8 lg:flex-row lg:items-end">
          <div>
            <p class="eyebrow">Press Capacity</p>
            <h2 class="section-title mt-5 max-w-3xl">Capacity built for demanding programs.</h2>
          </div>
          <a
            class="capabilities-spec-action ghost-button w-fit max-w-full px-5 py-4 text-center sm:px-6"
            href={pressSpecificationsUrl}
            target="_blank"
            rel="noopener noreferrer"
          >Press Specifications ↗</a>
        </div>
      </div>

      <div class="mt-12 grid border-l border-t border-line sm:grid-cols-2 xl:grid-cols-4">
        {pressProofs.map((proof) => (
          <article class="min-w-0 border-b border-r border-line p-6 sm:p-8">
            <p class:list={["font-black leading-none tracking-[-0.055em] text-foreground", proof.value.length > 7 ? "text-[clamp(2rem,4vw,3.6rem)]" : "text-[clamp(3.25rem,6vw,5.4rem)]"]}>
              {proof.value}
            </p>
            <p class="mt-5 text-xs font-black uppercase tracking-[0.22em] text-muted">{proof.label}</p>
          </article>
        ))}
      </div>
      <p class="mt-7 max-w-3xl text-sm leading-relaxed text-muted">
        Machine-by-machine tonnage, bed size, stroke, shut height, and feed details are maintained in the official press specification document.
      </p>
    </div>
  </section>

  <section class="bg-paper py-20 text-paper-muted sm:py-24 lg:py-28">
    <div class="site-container">
      <div class="grid gap-7 md:grid-cols-[8rem_1fr] md:gap-10">
        <p class="text-xs font-black uppercase tracking-[0.24em] text-primary">03 · Services</p>
        <div>
          <p class="text-xs font-black uppercase tracking-[0.22em]">Core Capabilities</p>
          <h2 class="mt-5 max-w-4xl text-[clamp(2.4rem,4.6vw,4.5rem)] font-bold leading-[0.98] tracking-[-0.035em] text-ink">
            Engineering, tooling, and production—connected.
          </h2>
          <p class="mt-6 max-w-3xl text-lg leading-relaxed">
            Technical development and production services stay connected, giving customer teams a clearer path from part intent to repeatable manufacturing.
          </p>
        </div>
      </div>

      <div class="mt-14 grid border-l border-t border-paper-line md:grid-cols-2 lg:grid-cols-3">
        {coreCapabilities.map((capability) => (
          <article class="group flex min-h-80 flex-col border-b border-r border-paper-line p-7 transition-colors hover:bg-ink hover:text-muted sm:p-8">
            <p class="text-xs font-black tracking-[0.2em] text-primary">{capability.number}</p>
            <h3 class="mt-auto pt-12 text-2xl font-bold text-ink transition-colors group-hover:text-foreground">{capability.title}</h3>
            <p class="mt-5 leading-relaxed">{capability.copy}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-secondary py-20 text-foreground sm:py-24 lg:py-28">
    <div class="site-container">
      <div class="grid gap-12 lg:grid-cols-[minmax(19rem,0.7fr)_minmax(0,1.3fr)] lg:gap-20">
        <div class="lg:sticky lg:top-32 lg:self-start">
          <p class="text-xs font-black uppercase tracking-[0.24em] text-foreground/65">04 · Integrated Production</p>
          <MediaPlaceholder
            slotId="03"
            label="Finished Assembly"
            suggestedSubject="Finished welded assembly or multi-part stamped component photographed with clear geometry and material detail."
            aspect="portrait"
            tone="oxblood"
            class="mx-auto mt-8 w-full max-w-sm lg:mx-0"
          />
        </div>

        <div>
          <p class="text-sm font-black uppercase tracking-[0.24em] text-foreground/65">Metal Assemblies</p>
          <h2 class="mt-5 max-w-4xl text-[clamp(2.6rem,5vw,5rem)] font-bold leading-[0.96] tracking-[-0.04em]">
            Simplify Your Supply Chain. Reduce Risk. Accelerate Production.
          </h2>
          <p class="mt-7 max-w-3xl text-lg leading-relaxed text-foreground/80">
            Purchasing and engineering teams need more than isolated components. By connecting precision stampings with welding, fastening, hardware insertion, and mechanical assembly, BRP helps reduce coordination burden and supports a smoother path from design through launch and production.
          </p>

          <ul class="mt-9 flex flex-wrap gap-2" aria-label="Metal assembly capabilities">
            {assemblyCapabilities.map((capability) => (
              <li class="border border-foreground/25 px-4 py-3 text-xs font-black uppercase tracking-[0.14em]">{capability}</li>
            ))}
          </ul>

          <div class="mt-12 grid border-l border-t border-foreground/20 sm:grid-cols-2">
            {assemblyOutcomes.map((outcome, index) => (
              <article class="border-b border-r border-foreground/20 p-6 sm:p-7">
                <p class="text-xs font-black tracking-[0.18em] text-foreground/55">0{index + 1}</p>
                <h3 class="mt-7 text-xl font-bold">{outcome.title}</h3>
                <p class="mt-3 leading-relaxed text-foreground/70">{outcome.copy}</p>
              </article>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-paper py-20 text-paper-muted sm:py-24 lg:py-28">
    <div class="site-container">
      <div class="grid items-start gap-12 lg:grid-cols-[minmax(0,1fr)_minmax(0,1fr)] lg:gap-20">
        <div class="lg:sticky lg:top-32 lg:self-start">
          <p class="text-xs font-black uppercase tracking-[0.24em] text-primary">05 · Joining</p>
          <MediaPlaceholder
            slotId="04"
            label="Welding & Automation"
            suggestedSubject="Robotic welding cell, weld-detail close-up, or operator working alongside production automation."
            aspect="landscape"
            tone="light"
            class="mt-8 w-full max-w-2xl"
          />
        </div>

        <div>
          <p class="text-xs font-black uppercase tracking-[0.22em]">Automotive Welding Services</p>
          <h2 class="mt-5 text-[clamp(2.4rem,4.6vw,4.5rem)] font-bold leading-[0.98] tracking-[-0.035em] text-ink">
            Engineering-driven welding. Production-proven results.
          </h2>
          <p class="mt-7 text-lg leading-relaxed">
            BRP combines welding process knowledge, production automation, and in-process verification to support durable multi-component assemblies for automotive OEM, Tier 1, and Tier 2 programs.
          </p>
          <p class="mt-5 leading-relaxed">
            Integrating stamping, welding, and assembly under one manufacturing system reduces supplier complexity, limits handoffs, and gives launch teams a clearer path to stable production.
          </p>

          <ul class="mt-9 grid border-l border-t border-paper-line sm:grid-cols-2" aria-label="Automotive welding capabilities">
            {weldingCapabilities.map((capability, index) => (
              <li class="flex min-h-20 items-center gap-4 border-b border-r border-paper-line p-4 text-sm font-bold text-ink">
                <span class="text-[0.65rem] font-black tracking-[0.16em] text-primary">{String(index + 1).padStart(2, "0")}</span>
                <span>{capability}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="relative overflow-hidden border-t border-line bg-background py-20 text-muted sm:py-24 lg:py-28">
    <div class="pointer-events-none absolute -bottom-28 right-0 text-[24rem] font-black leading-none text-foreground/[0.025]" aria-hidden="true">
      Q
    </div>
    <div class="site-container relative z-10">
      <div class="grid gap-7 md:grid-cols-[8rem_1fr] md:gap-10">
        <p class="text-xs font-black uppercase tracking-[0.24em] text-primary">06 · Quality</p>
        <div>
          <p class="eyebrow">Quality Systems</p>
          <h2 class="section-title mt-5 max-w-4xl">Producing quality. Delivering confidence.</h2>
          <p class="mt-6 max-w-3xl text-lg leading-relaxed">
            Quality is built into the manufacturing process through validation, dimensional inspection, statistical controls, and automotive-focused systems.
          </p>
        </div>
      </div>

      <div class="mt-12 grid border-l border-t border-line sm:grid-cols-2 xl:grid-cols-4">
        {qualityProofs.map((proof, index) => (
          <article class="min-h-64 border-b border-r border-line p-6 sm:p-8">
            <p class="text-xs font-black tracking-[0.2em] text-primary">0{index + 1}</p>
            <h3 class="mt-14 text-2xl font-bold text-foreground">{proof.title}</h3>
            <p class="mt-4 leading-relaxed">{proof.copy}</p>
          </article>
        ))}
      </div>

      <div class="mt-16 flex flex-col justify-between gap-8 border-t border-line pt-10 lg:flex-row lg:items-end">
        <p class="max-w-4xl text-[clamp(2.2rem,4.5vw,4.6rem)] font-bold leading-[0.98] tracking-[-0.035em] text-foreground">
          Your next manufacturing partner should reduce risk—not add it.
        </p>
        <a class="btn-red shrink-0 px-8 py-5" href="/#contact">Start a Project</a>
      </div>
    </div>
  </section>
</SiteLayout>

<style>
  .capabilities-spec-action {
    white-space: normal;
  }
</style>
